<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for the bundled Python interpreter.

  The app ships a relocatable CPython and runs the `hyperspell` daemon out of a
  venv at ~/.hyperspell/venv (Option A: the venv lives OUTSIDE the signed bundle
  so the daemon's existing wheel self-update doesn't invalidate the signature).
  Because the interpreter loads C-extension site-packages from that
  user-writable location, the notarized bundle needs these entitlements or
  Gatekeeper's library validation will refuse to load them.

  RISK (see plan): getting this exactly right for an embedded interpreter that
  imports user-writable site-packages is the fiddliest part of the project.
  Prototype sign+notarize+launch+`import httpx` end-to-end before relying on it.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
