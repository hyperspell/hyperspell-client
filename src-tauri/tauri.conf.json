{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hyperspell",
  "version": "0.1.0",
  "identifier": "com.hyperspell.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": false,
    "windows": [
      {
        "title": "Hyperspell",
        "label": "main",
        "width": 420,
        "height": 600,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "Hyperspell"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "resources": {
      "resources/runtime": "runtime"
    },
    "shortDescription": "Keeps your company brain in sync and queryable from local AI tools.",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "exceptionDomain": ""
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://app.hyperspell.com/desktop/latest.json"],
      "pubkey": "REPLACE_WITH_OUTPUT_OF__npm_run_tauri_signer_generate"
    }
  }
}
